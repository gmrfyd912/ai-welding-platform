{
  "expo": {
    "name": "AI 용접 진단",
    "slug": "ai-welding-diagnosis",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "aiwelding",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aiwelding"
    },
    "android": {
      "package": "com.aiwelding",
      "adaptiveIcon": {
        "backgroundColor": "#0A0E1A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "용접 결과물 사진을 업로드하기 위해 갤러리 접근이 필요합니다.",
          "cameraPermission": "용접 결과물 사진을 촬영하기 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "용접 결과물 사진을 촬영하기 위해 카메라 접근이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
